<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-col">
      <div class="footer-brand">
        <img src="/assets/img/logo-128.png" width="40" height="40" alt="">
        <span class="name">Camelid Research Studies APS</span>
      </div>
      <p>{{ T.tagline }}</p>
    </div>
    <div class="footer-col">
      <h4>{{ T.footer_pages }}</h4>
      <ul>
        {% for item in T.nav %}<li><a href="{{ item.url | locale_url }}">{{ item.label }}</a></li>{% endfor %}
      </ul>
    </div>
    <div class="footer-col">
      <h4>{{ T.footer_contact }}</h4>
      <ul>
        <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        {% for s in site.social %}<li><a href="{{ s.url }}">{{ s.label }}</a></li>{% endfor %}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>&copy; {% year %} {{ site.legalName }} · C.F. {{ site.titolare.codiceFiscale }}</span>
    <a href="{{ '/privacy-policy/' | locale_url }}">{{ T.privacy }}</a>
  </div>
</footer>
