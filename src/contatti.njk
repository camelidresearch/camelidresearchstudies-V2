---
layout: base.njk
title: Contatti
eyebrow: Contatti
heading: Collabora <em>con noi</em>
lead: Siamo aperti a collaborazioni con università, enti del terzo settore, allevatori e professionisti. Scrivici per ricerca, partnership o informazioni.
description: "Contatta Camelid Research Studies APS per collaborazioni di ricerca, partnership o informazioni su alpaca, lama e benessere dei camelidi."
---
<section class="bg-soft">
  <div class="container">
    <div class="split">
      <div class="contact-info">
        <p>Raccontaci la tua richiesta o la tua proposta: ti risponderemo al più presto.</p>
        <div class="contact-detail"><div class="label">Email</div><div class="value"><a href="mailto:{{ site.email }}">{{ site.email }}</a></div></div>
        <div class="contact-detail"><div class="label">Sede</div><div class="value">Italia</div></div>
        <div class="contact-detail"><div class="label">Forma</div><div class="value">{{ site.legalForm }} · iscritta al RUNTS</div></div>
      </div>
      <div>
        <form id="contact-form" class="contact-form">
          <input type="hidden" name="access_key" value="d44d6fc6-3352-4171-9dfd-8dd1f07c48e6">
          <input type="hidden" name="subject" value="Nuovo messaggio dal sito Camelid Research Studies">
          <input type="hidden" name="from_name" value="Sito Camelid Research Studies">

          <label for="nome">Nome e cognome</label>
          <input id="nome" type="text" name="nome" placeholder="Mario Rossi" required>

          <label for="email">Email</label>
          <input id="email" type="email" name="email" placeholder="nome@esempio.it" required>

          <label for="organizzazione">Organizzazione / Ente (opzionale)</label>
          <input id="organizzazione" type="text" name="organizzazione" placeholder="Università, associazione, allevamento…">

          <label for="messaggio">Messaggio</label>
          <textarea id="messaggio" name="messaggio" placeholder="Descrivi brevemente la tua richiesta o proposta" required></textarea>

          <!-- honeypot anti-spam di Web3Forms: nascosto, lo riempiono solo i bot -->
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">

          <button type="submit" class="btn-primary" style="width:100%;justify-content:center">Invia messaggio</button>
          <p id="form-result" role="status" aria-live="polite" style="display:none;margin-top:1rem;font-size:14px"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  var form = document.getElementById('contact-form');
  var result = document.getElementById('form-result');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    var original = btn.textContent;
    btn.disabled = true; btn.textContent = 'Invio in corso…';
    result.style.display = 'none';
    fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) {
          form.reset();
          result.style.color = 'var(--accent-deep)';
          result.textContent = 'Grazie, il messaggio è stato inviato. Ti risponderemo al più presto.';
        } else {
          result.style.color = '#b00020';
          result.textContent = 'Si è verificato un errore. Riprova o scrivici via email.';
        }
        result.style.display = 'block';
      })
      .catch(function () {
        result.style.color = '#b00020';
        result.textContent = 'Errore di rete. Riprova o scrivici via email.';
        result.style.display = 'block';
      })
      .finally(function () { btn.disabled = false; btn.textContent = original; });
  });
})();
</script>
